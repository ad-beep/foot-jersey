# ─── Site ─────────────────────────────────────────────────────
# Canonical production URL — used in emails, sitemap, canonical tags, and
# unsubscribe links. Keep this in sync with the real domain.
NEXT_PUBLIC_SITE_URL=https://shopfootjersey.com
NEXT_PUBLIC_SITE_NAME=FootJersey

# ─── Google Sheets (catalogue + orders log + discount codes) ──
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Cache TTL for the Sheets catalogue (seconds)
CACHE_TTL=1800

# ─── Firebase (client SDK — safe to expose) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (server-only — KEEP SECRET) ───────────
# All server-side Firestore access uses these. Never expose to the browser.
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Admin access ─────────────────────────────────────────────
# Comma-separated admin emails. Prefer ADMIN_EMAILS (server-only) over
# NEXT_PUBLIC_ADMIN_EMAILS so the list is never shipped to the browser.
ADMIN_EMAILS=you@example.com

# ─── PayPal (cards + wallet) ──────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── Email (Gmail SMTP via nodemailer) ────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Cron + signing secrets (server-only) ─────────────────────
# Authenticates the Vercel cron endpoints AND signs unsubscribe links.
CRON_SECRET=
# Optional: dedicated key for unsubscribe-link signing (falls back to CRON_SECRET).
UNSUBSCRIBE_SECRET=

# ─── Vercel Analytics (admin dashboard visits) ────────────────
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
