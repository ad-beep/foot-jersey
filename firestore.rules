rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check ──────────────────────────────────────────────────────
    // Matches the admin email(s). Update if you change the admin account.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'adibhazz@gmail.com';
    }

    // ── Architecture note ────────────────────────────────────────────────
    // ALL server-side writes now go through the Firebase Admin SDK (API routes
    // and cron jobs), which bypasses these rules entirely. Therefore the client
    // SDK only needs:
    //   • the signed-in admin (browser) reading/managing data on /admin pages
    //   • each signed-in user reading/writing their own /users profile
    // Everything else is denied to the client. Public site features (orders,
    // reviews, stock alerts, newsletter, abandoned carts, exit-intent leads,
    // order tracking, order confirmation) are served exclusively by server API
    // routes using the Admin SDK — the browser never touches those collections
    // directly. This closes the previous "allow create/update: if true" holes.

    // ── Orders ────────────────────────────────────────────────────────────
    // Created/updated by server API routes (Admin SDK). The admin browser reads
    // and manages orders on /admin/orders, so allow admin read/write there.
    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Each authenticated user can only read and write their own profile.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Order counter ─────────────────────────────────────────────────────
    // Server-only (Admin SDK). No client access.
    match /meta/{docId} {
      allow read, write: if false;
    }

    // ── Admin Audit Log ───────────────────────────────────────────────────
    // Written server-side (Admin SDK) and by the admin browser for actions done
    // directly from /admin (e.g. deleting an order). Only the admin can create;
    // entries are immutable (no update/delete from the client).
    match /adminAuditLog/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Captured PayPal Payments (recovery records) ───────────────────────
    // Server-only (Admin SDK). The admin views orphaned payments via an API.
    match /capturedPayments/{docId} {
      allow read, write: if false;
    }

    // ── Captured BIT Payments (idempotency guard) ─────────────────────────
    // Server-only (Admin SDK).
    match /capturedBitPayments/{docId} {
      allow read, write: if false;
    }

    // ── Discount Usage counters ───────────────────────────────────────────
    // Server-only (Admin SDK) — written by the orders route, read by validation.
    match /discountUsage/{code} {
      allow read, write: if false;
    }

    // ── Product Reviews ───────────────────────────────────────────────────
    // Server-only (Admin SDK) — read and written by /api/reviews.
    match /productReviews/{reviewId} {
      allow read, write: if false;
    }

    // ── Stock Alerts ──────────────────────────────────────────────────────
    // Server-only (Admin SDK) — written by /api/stock-alerts.
    match /stockAlerts/{alertId} {
      allow read, write: if false;
    }

    // ── Newsletter Emails ─────────────────────────────────────────────────
    // Server-only (Admin SDK) — written by /api/newsletter.
    match /newsletterEmails/{docId} {
      allow read, write: if false;
    }

    // ── Exit-intent Leads ─────────────────────────────────────────────────
    // Written server-side (Admin SDK). Admin reads them on /admin/marketing.
    match /exitIntentLeads/{leadId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Abandoned Carts ───────────────────────────────────────────────────
    // Written server-side (Admin SDK). Admin reads them on /admin/marketing.
    match /abandonedCarts/{cartId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Marketing Spends (admin-logged ad-spend entries) ──────────────────
    // The admin browser reads and writes these on /admin/marketing.
    match /marketingSpends/{spendId} {
      allow read, write: if isAdmin();
    }
  }
}
