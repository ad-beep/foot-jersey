rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check ──────────────────────────────────────────────────────
    // Matches the value of NEXT_PUBLIC_ADMIN_EMAILS in your Vercel dashboard.
    // If you have multiple admin emails, add them with || operators.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'adibhazz@gmail.com';
    }

    // ── Orders ────────────────────────────────────────────────────────────
    // • create + update: allowed unauthenticated — the Next.js API routes
    //   (/api/orders and /api/orders/approve-bit) use the Firebase client SDK
    //   on the server without a user session. Until those routes are migrated
    //   to the Firebase Admin SDK, these must remain open.
    // • read + delete: restricted to the admin only.
    match /orders/{orderId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Each authenticated user can only read and write their own profile.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Order counter (used by server-side API, unauthenticated) ──────────────
    match /meta/{docId} {
      allow read, write: if true;
    }

    // ── Admin Audit Log ───────────────────────────────────────────────────────
    // Writes come from server-side API routes (no auth session) — allow create.
    // Reads restricted to admin only.
    match /adminAuditLog/{entryId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // ── Captured Payments (PayPal recovery records) ───────────────────────────
    // Written by capture-order route and orders route (no auth session).
    // Read/delete restricted to admin only.
    match /capturedPayments/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // ── Discount Usage counters ───────────────────────────────────────────────
    // Written by orders route (no auth session). Read by discount validation.
    // Admin can read/write for management.
    match /discountUsage/{code} {
      allow read, write: if true;
    }
  }
}
